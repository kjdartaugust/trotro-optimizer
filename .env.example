# ---------- Backend ----------
# Postgres + PostGIS connection (async driver for the app, sync for migrations)
DATABASE_URL=postgresql+asyncpg://trotro:trotro@db:5432/trotro
DATABASE_URL_SYNC=postgresql+psycopg://trotro:trotro@db:5432/trotro

# Redis cache
REDIS_URL=redis://redis:6379/0

# Auth. In production point this at your Supabase project's JWT secret so Supabase-issued
# access tokens verify. In dev, DEV_AUTH=true enables the /auth/token dev mint endpoint.
SUPABASE_JWT_SECRET=super-secret-dev-jwt-signing-key-change-me
JWT_ALGORITHM=HS256
DEV_AUTH=true

# Crowdsourcing / trust tuning
AUTO_APPROVE_THRESHOLD=0.75
DEFAULT_TRUST_SCORE=20
FARE_REPORT_HALFLIFE_DAYS=30

# CORS (comma-separated origins the API accepts)
CORS_ORIGINS=http://localhost:3000
# Optional regex matching all deploy URLs of your frontend (Vercel per-deploy URLs change).
# Example: CORS_ORIGIN_REGEX=https://.*\.vercel\.app  — leave blank to use only CORS_ORIGINS.
CORS_ORIGIN_REGEX=

# ---------- Postgres container ----------
POSTGRES_USER=trotro
POSTGRES_PASSWORD=trotro
POSTGRES_DB=trotro

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:8000
# Optional: MapLibre style / vector tile URL. Leave blank to use the bundled offline raster fallback.
NEXT_PUBLIC_MAP_STYLE_URL=
